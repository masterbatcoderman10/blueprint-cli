{
  "name": "blueprint-agentic-development",
  "version": "1.1.0",
  "description": "Plan in detail. Execute in parallel. Blueprint is the agentic development framework that gives Claude Code, Codex & Cursor autonomous, structured execution across milestones, phases, and parallel streams.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/masterbatcoderman10/blueprint-cli.git"
  },
  "homepage": "https://github.com/masterbatcoderman10/blueprint-cli#readme",
  "bugs": {
    "url": "https://github.com/masterbatcoderman10/blueprint-cli/issues"
  },
  "keywords": [
    "blueprint",
    "claude-code",
    "claude",
    "codex",
    "cursor",
    "agentic-development",
    "ai-agent",
    "ai-agents",
    "coding-agent",
    "autonomous-coding",
    "llm-workflow",
    "ai-productivity",
    "ai-assisted-development",
    "project-planning",
    "task-management",
    "kanban",
    "developer-tooling",
    "workflow-orchestration",
    "scaffolding",
    "cli"
  ],
  "bin": {
    "blueprint": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "dist/spa",
    "templates",
    "skills"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:board": "vite",
    "build:spa": "vite build",
    "build": "tsc && npm run build:spa",
    "prepack": "tsc 1>&2",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release:pack:verify": "tsx src/release/verify-package-artifact.ts",
    "release:check": "tsx src/release/run-release-check.ts",
    "release:check:ci": "npm run release:check",
    "release:check:publish": "npm run release:check",
    "release:publish:preflight": "tsx src/release/run-publish-preflight.ts",
    "release:version-check": "tsx src/release/run-version-check.ts"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "jsdom": "^26.0.0",
    "svelte": "^5.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "better-sqlite3": "^12.10.0"
  }
}
